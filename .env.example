# Copy to .env and adjust. All variables are optional (sensible defaults apply).
DATA_ROOT=data
ARTIFACT_ROOT=artifacts
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SPARK_MASTER=local[*]
SPARK_TIMEZONE=Australia/Melbourne
# Use a small sample for fast local/demo training:
MODEL_SAMPLE_FRACTION=1.0
MODEL_SEED=2025
