# Copy to .env and adjust. All variables are optional (sensible defaults apply).
DATA_ROOT=data
ARTIFACT_ROOT=artifacts
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SPARK_MASTER=local[*]
SPARK_TIMEZONE=Australia/Melbourne
# Use a small sample for fast local/demo training:
MODEL_SAMPLE_FRACTION=1.0
MODEL_SEED=2025
# Port the Kafka->Prometheus exporter serves /metrics on (streaming dashboard):
DASHBOARD_EXPORTER_PORT=8000
# Grafana admin login for the dashboard stack (override before any non-local use):
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
